# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=NWI Fun Ball <tickets@yourdomain.com>

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Site URL (for Stripe redirects and ticket verification links)
# Prefer SITE_URL (server-only, always read at runtime). NEXT_PUBLIC_SITE_URL is fallback.
SITE_URL=https://yoursite.com
NEXT_PUBLIC_SITE_URL=https://yoursite.com

# Stripe Dashboard → Webhooks: endpoint URL
# ${NEXT_PUBLIC_SITE_URL}/api/webhooks/stripe
